# Database (optional in dev — falls back to file:local.db)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# AI nutrition analysis — set ONE provider key
AI_PROVIDER=google              # google | anthropic | openai
GOOGLE_GENERATIVE_AI_API_KEY=   # required if AI_PROVIDER=google
ANTHROPIC_API_KEY=              # required if AI_PROVIDER=anthropic
OPENAI_API_KEY=                 # required if AI_PROVIDER=openai
